# PipelineIQ Portal — Backend environment template
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.

# App-level login password (single tenant, set during setup)
APP_PASSWORD=

# Full SQLAlchemy URL. Local dev example:
#   sqlite:///./portal.db
# Production example:
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Secret used to sign JWT session tokens. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# Slack incoming webhook for contact-form submissions / alerts
SLACK_WEBHOOK_URL=
